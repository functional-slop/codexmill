# CodexMill configuration — copy to .env and edit, or set these in docker-compose.yml / your shell.
# Everything here is OPTIONAL: you can configure the AI engine in the Settings UI after first run.
# Nothing is required to start the app.

# --- Secrets at rest (recommended) ---------------------------------------------------------------
# Encrypts saved API keys / OIDC secrets in the config store. Generate once: openssl rand -hex 32
# If unset, the app auto-generates and persists one in the data dir.
CODEXMILL_SECRET_KEY=

# --- AI engine (optional; else set it in Settings) -----------------------------------------------
# CodexMill talks to ANY OpenAI-compatible endpoint. Point it at a cloud key or a local Ollama.
# Cloud example (Google Gemini):
#CODEXMILL_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#CODEXMILL_MODEL=gemini-2.5-flash
#CODEXMILL_API_KEY=your-key-here
# Local Ollama example (inside Docker use host.docker.internal, NOT localhost):
#CODEXMILL_BASE_URL=http://host.docker.internal:11434/v1
#CODEXMILL_MODEL=llama3.2
#CODEXMILL_API_KEY=ollama

# Default Ollama URL the Settings page suggests (helps Docker users reach the host's Ollama).
CODEXMILL_OLLAMA_URL=http://host.docker.internal:11434/v1

# --- AGPL source link (set if you modify + serve CodexMill to others) -----------------------------
# The footer links here so your users can get your modified source, as AGPL-3.0 §13 requires.
#CODEXMILL_SOURCE_URL=https://github.com/YOURNAME/codexmill

# --- Optional sign-in on a shared/hosted instance (OIDC; off unless all four are set) -------------
#CODEXMILL_OIDC_ISSUER=https://your-idp/application/o/codexmill
#CODEXMILL_OIDC_CLIENT_ID=
#CODEXMILL_OIDC_CLIENT_SECRET=
#CODEXMILL_ADMIN_EMAILS=you@example.com

# --- Other optional knobs ------------------------------------------------------------------------
# Break-glass recovery token to unlock Settings if you're ever locked out (never put it in a URL):
#CODEXMILL_SETUP_TOKEN=
# Require HTTPS for the session cookie (set when serving behind TLS to the public internet):
#CODEXMILL_HTTPS_ONLY=true
# Session lifetime in seconds (default 7 days):
#CODEXMILL_SESSION_MAX_AGE=604800
# Generation sampling temperature (default 0.8) and per-LLM-call timeout in seconds (default 120):
#CODEXMILL_TEMPERATURE=0.8
#CODEXMILL_TIMEOUT=120
# Where the config store + saved bibles live (default: OS state dir; the Docker image sets /data):
#CODEXMILL_CONFIG_DIR=/data
# Database URL. Default is a SQLite file under the config dir; set a Postgres URL to use Postgres:
#CODEXMILL_DATABASE_URL=postgresql+psycopg://user:pass@host:5432/codexmill
# Optional per-user quota — max generations per rolling window (0 = unlimited) + the window length:
#CODEXMILL_MAX_GENERATIONS=0
#CODEXMILL_RATE_WINDOW_HOURS=24
# Extra OIDC scopes beyond the default (openid email profile):
#CODEXMILL_OIDC_SCOPE=openid email profile
# Show a "Send feedback" link in the footer pointing at this address (empty = no link shown):
#CODEXMILL_FEEDBACK_EMAIL=
